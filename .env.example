# ════════════════════════════════════════════════════════════════════════════
# ClawdBot Environment Template
# Copy to .env: cp .env.example .env
#
# The installer (curl … | bash) fills this automatically.
# Free AI and RPC are pre-configured — no keys required to get started.
# Public surfaces:
#   Hub:      https://github.com/solizardking/solana-clawd
#   Runtime:  https://github.com/Solizardking/clawdbot-go
#   Gateway:  https://zk.x402.wtf
#   Terminal: https://cheshireterminal.ai
# ════════════════════════════════════════════════════════════════════════════

# ── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5002
APP_ORIGIN=http://localhost:5002
APP_URL=http://localhost:5002
VITE_APP_URL=http://localhost:5002

# ── Install identity (set by installer) ──────────────────────────────────────
CLAWDBOT_INSTALL_ID=
CLAWDBOT_AGENT_DNA_ID=
CLAWDBOT_INSTALL_RECEIPT=~/.clawdbot/install.json
CLAWDBOT_SKIP_SKILL_SEED=0
CLAWDBOT_SOURCE_MODE=archive
# CLAWDBOT_REF=main

# ── Web console hardening ────────────────────────────────────────────────────
CLAWDBOT_CORS_ORIGINS=
CLAWDBOT_TRUST_PROXY_HEADERS=0
CLAWDBOT_WEB_EXPOSE_SECRETS=0
CLAWDBOT_WEB_READ_TIMEOUT_SECONDS=15
CLAWDBOT_WEB_WRITE_TIMEOUT_SECONDS=300
CLAWDBOT_WEB_IDLE_TIMEOUT_SECONDS=120

# ── Admin / Auth ─────────────────────────────────────────────────────────────
# ADMIN_SECRET=
# CLAWD_ADMIN_KEY=
# SESSION_SECRET=
CLAWD_LIVE=FALSE
CLAWD_AUTOSTART=false

# ── Free AI via zkrouter ─────────────────────────────────────────────────────
ZKROUTER_BASE_URL=https://clawdrouter-zk.fly.dev/v1
ZKROUTER_API_KEY=clawdbot-free

# ── OpenRouter API Keys (optional — removes rate limits) ────────────────────
# OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_DEFAULT_FREE_MODEL=nvidia/llama-nemotron-rerank-vl-1b-v2:free
OPENROUTER_OPUS=anthropic/claude-opus-4.8-fast
OPENROUTER_CLAUDE=anthropic/claude-sonnet-4.5
OPENROUTER_GROK=x-ai/grok-4.3
OPENROUTER_DEEP=deepseek/deepseek-v3.2
OPENROUTER_GLM=z-ai/glm-5.2
OPENROUTER_TRADING_MODEL=z-ai/glm-5.2
OPENROUTER_FUSION=openrouter/fusion
OPENROUTER_GPT=openai/gpt-5.2
OPENROUTER_GEMINI_IMAGE=google/gemini-3.1-flash-image

# ── AI Provider Keys (optional) ──────────────────────────────────────────────
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# HONCHO_API_KEY=
# REDPILL_API_KEY=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=false

# ── Solana RPC ───────────────────────────────────────────────────────────────
# Free RPC via zk.x402.wtf. Replace with your Helius/QuickNode key for higher limits.
SOLANA_RPC_URL=https://zk.x402.wtf/api/solana/rpc-public
HELIUS_API_KEY=
HELIUS_RPC_URL=https://zk.x402.wtf/api/solana/rpc-public
HELIUS_WSS_URL=wss://zk.x402.wtf/api/solana/rpc-public
# BIRDEYE_API_KEY=your-birdeye-key

# ── Agent wallet (generated by installer) ─────────────────────────────────────
AGENT_WALLET_PUBLIC_KEY=
AGENT_WALLET_KEYPAIR=~/.clawdbot/workspace/agent-wallet.json
SOLANA_WALLET_PUBKEY=
SOLANA_WALLET_KEYPAIR=~/.clawdbot/workspace/agent-wallet.json
CLAWD_TOKEN_MINT=8cHzQHUS2s2h8TzCmfqPKYiM4dSt4roa3n7MyRLApump
CLAWD_DECIMALS=6

# ── Startup funding ──────────────────────────────────────────────────────────
CLAWDBOT_STARTUP_SOL_LAMPORTS=69420000
CLAWDBOT_STARTUP_SOL_AMOUNT=0.069420
CLAWDBOT_STARTUP_CLAWD_TOKENS=1000

# ── Phoenix / Vulcan perps ──────────────────────────────────────────────────
VULCAN_BIN=vulcan
VULCAN_DEFAULT_MODE=paper
VULCAN_PAPER_BALANCE=10000
VULCAN_WALLET_NAME=clawd
VULCAN_MAX_STEP_NOTIONAL_USDC=100
VULCAN_MAX_TOTAL_NOTIONAL_USDC=500
VULCAN_MAX_PRICE_DRIFT_BPS=75
VULCAN_MAX_EXPOSURE_RATIO=2
VULCAN_TIMEOUT_SECONDS=30

# ── Imperial Trading (optional) ─────────────────────────────────────────────
# IMPERIAL_API_KEY=
# IMPERIAL_WALLET=
IMPERIAL_LIVE=false

# ── DFlow / Jupiter Trading (optional) ───────────────────────────────────────
# DFLOW_API_KEY=
# JUPITER_API_KEY=
JUPITER_TOKENS_BASE=https://api.jup.ag/tokens/v2

# ── Staking (devnet) ─────────────────────────────────────────────────────────
# OPENCLAWD_AGENT_STAKING_PROGRAM_ID=
# OPENCLAWD_STAKING_RPC_URL=https://api.devnet.solana.com

# ── Database (optional) ──────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host/db
# CONVEX_URL=https://your-project.convex.cloud
# CONVEX_DEPLOY_KEY=

# ── Upstash / QStash (optional) ─────────────────────────────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=

# ── Storage (optional) ──────────────────────────────────────────────────────
# TIGRIS_ACCESS_KEY_ID=
# TIGRIS_SECRET_ACCESS_KEY=
# TIGRIS_PUBLIC_URL=
# PINATA_API_KEY=
# PINATA_API_SECRET=

# ── Channels (optional) ─────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_BOT_USERNAME=@your-bot
# DISCORD_BOT_TOKEN=your-discord-token

# ── Twitter / Social Auth (optional) ────────────────────────────────────────
# TWITTER_CONSUMER_KEY=
# TWITTER_SECRET_KEY=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── Clerk Auth (optional) ───────────────────────────────────────────────────
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ── LiveKit Voice (optional) ────────────────────────────────────────────────
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# ── Browser Use (optional) ──────────────────────────────────────────────────
# BROWSERUSE_API_KEY=

# ── OODA Worker ─────────────────────────────────────────────────────────────
# OODA_WORKER_URL=https://ooda-decide.x402.workers.dev
# OODA_WORKER_TOKEN=

# ── Clawd ZK Agent ──────────────────────────────────────────────────────────
# CLAWD_ZK_RPC_URL=https://zk.x402.wtf/api/solana/rpc-public
# CLAWD_ZK_NETWORK=mainnet
# ZK_SHARK_RPC_URL=https://zk.x402.wtf/api/solana/rpc-public

# ── Local Clawd catalogs (read-only discovery) ───────────────────────────────
# CLAWDBOT_SKILLS_DIR=~/.clawdbot/skills
# CLAWDBOT_AGENTS_DIR=~/.clawdbot/agents
# CLAWDBOT_ZK_PRIMITIVES_DIR=./zk-primitives