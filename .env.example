# ════════════════════════════════════════════════════════════════════════════
# ClawdBot Environment Template
# Copy to .env: cp .env.example .env
#
# The installer (curl … | bash) fills this automatically.
# Free AI and RPC are pre-configured — no keys required to get started.
# Public surfaces:
#   Hub:      https://github.com/solizardking/solana-clawd
#   Runtime:  https://github.com/Solizardking/clawdbot-go
#   Gateway:  https://zk.x402.wtf
#   Terminal: https://cheshireterminal.ai
# ════════════════════════════════════════════════════════════════════════════

# ── Install identity (set by installer) ──────────────────────────────────────
CLAWDBOT_INSTALL_ID=

# ── Birth skill seed ────────────────────────────────────────────────────────
# Installer/onboard seeds Solizardking/skills and samber/cc-skills-golang.
# Set to 1 to skip networked skill seeding during install/launch.
CLAWDBOT_SKIP_SKILL_SEED=0

# ── Free AI via zkrouter ─────────────────────────────────────────────────────
# Powered by zk.x402.wtf — sovereign AI routing for $CLAWD holders + clawdbot installs.
# No API key needed for the free tier. Set ZKROUTER_API_KEY if you have a custom key.
ZKROUTER_BASE_URL=https://clawdrouter-zk.fly.dev/v1
ZKROUTER_API_KEY=clawdbot-free

# ── Solana RPC ───────────────────────────────────────────────────────────────
# SolanaTracker-backed RPC proxy — no key required for clawdbot installs.
# Override with your own Helius/QuickNode URL for higher rate limits.
SOLANA_RPC_URL=https://zk.x402.wtf/api/solana/rpc-public
HELIUS_RPC_URL=https://zk.x402.wtf/api/solana/rpc-public

# ── Optional: your own keys (removes rate limits) ────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# HELIUS_API_KEY=your-helius-api-key
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# BIRDEYE_API_KEY=your-birdeye-key

# ── Wallet (required for live trading, optional for read-only / paper trading)
# WALLET_PRIVATE_KEY=your-base58-encoded-private-key
# WALLET_ADDRESS=your-solana-wallet-address

# ── Phoenix perpetual futures (https://phoenix.trade) ────────────────────────
# Public endpoints work without a key. Set PHOENIX_WALLET_KEY_PATH for live trading.
# PHOENIX_API_URL=https://perp-api.phoenix.trade
# PHOENIX_WALLET_KEY_PATH=~/.config/solana/id.json  # Solana CLI keypair JSON

#───────────────────────────────────────


# ── Channels (optional) ───────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# DISCORD_BOT_TOKEN=your-discord-token

# ── xAI Grok (optional override) ─────────────────────────────────────────────
# XAI_API_KEY=your-xai-key
# XAI_MODEL=grok-4.3

# ── Supabase memory (optional) ───────────────────────────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-key

# ── Clawd ZK Agent (optional) ───────────────────────────────────────────────
# CLAWD_ZK_RPC_URL=https://zk.x402.wtf/api/solana/rpc-public
# CLAWD_ZK_PHOTON_URL=https://zk.x402.wtf/api/solana/rpc-public
# CLAWD_ZK_NETWORK=mainnet
# ZK_SHARK_RPC_URL=https://zk.x402.wtf/api/solana/rpc-public
# ZK_SHARK_NETWORK=mainnet

# ── Local Clawd catalogs (optional, read-only discovery) ─────────────────────
# CLAWDBOT_SKILLS_DIR=/Users/8bit/skills/skills
# CLAWDBOT_AGENTS_DIR=/Users/8bit/agents/agents/src
# CLAWDBOT_ZK_PRIMITIVES_DIR=/Users/8bit/Agentics/clawdbot-go/zk-primitives
